CAGELEDGER_CONTACT_EMAIL=info@cellnucle.us
CAGELEDGER_LICENSE=Apache-2.0
CAGELEDGER_COPYRIGHT=© 2026 中山大学中山眼科中心 实验动物中心. Licensed under Apache-2.0.

# GitHub update check.
CAGELEDGER_REPOSITORY=Hugo-YH/CageLedger
CAGELEDGER_BRANCH=main
