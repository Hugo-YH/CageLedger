{
  "name": "cageledger",
  "private": true,
  "version": "0.5.25",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Hugo <info@cellnucle.us>",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "npm run build && python3 server.py",
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "benchmark": "python3 scripts/benchmark_performance.py",
    "check": "npm run typecheck && npm run test && python3 -m unittest discover -s tests -p 'test_*.py' && find src -name '*.js' -print0 | xargs -0 -n1 node --check && python3 -m py_compile server.py scripts/generate_iacuc_index.py scripts/benchmark_performance.py",
    "smoke:api": "node scripts/smoke_api.mjs",
    "package:offline": "bash scripts/package_offline.sh",
    "release:local": "bash scripts/release_local.sh"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-virtual": "^3.14.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
