  "scripts": {
    "start": "python3 server.py",
    "dev": "python3 server.py",
    "static": "python3 -m http.server 5173",
    "check": "node --check src/app.js && find src -name '*.js' -not -path 'src/app.js' -print0 | xargs -0 -n1 node --check && python3 -m py_compile server.py scripts/generate_iacuc_index.py",
    "smoke:api": "node scripts/smoke_api.mjs",
    "package:offline": "bash scripts/package_offline.sh",
    "release:local": "bash scripts/release_local.sh"
  }
}
